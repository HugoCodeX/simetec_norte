// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  role          String?
  dinero        Float         @default(0) // Dinero disponible del usuario
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  registros     Registro[]    // Registros creados por este usuario
  gastos        Gasto[]       // Gastos creados por este usuario

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Registro {
  id                   Int              @id @default(autoincrement())
  folio                String           @unique
  fecha                DateTime
  edificioCondominio   String?
  direccion            String
  deptoCasa            String?
  block                String?
  ciudad               String
  administrador        String
  empresaGas           String
  nombre               String
  rut                  String
  telefono             String?
  correoElectronico    String?
  numeroMedidor        String
  firma                String?          // Base64 de la imagen de firma
  defectosCriticos     DefectoCritico[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  createdBy            String?          // ID del usuario que creó el registro
  user                 User?            @relation(fields: [createdBy], references: [id])

  @@map("registro")
}

model DefectoCritico {
  id                   String   @id @default(cuid())
  tipo                 String
  instalacionAfectada  String
  registroId           Int
  registro             Registro @relation(fields: [registroId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("defecto_critico")
}

model Gasto {
  id          String   @id @default(cuid())
  folio       String
  fecha       DateTime
  item        String
  descripcion String?
  monto       Float
  archivo     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gasto")
}
